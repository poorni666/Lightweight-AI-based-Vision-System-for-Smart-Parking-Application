# Virtual environments
venv/
.venv/

# Datasets - keep private/local only
datasets/

# TFRecord / raw data files
*.record
*.tfrecord

# Model checkpoints - ignore generated weights, keep folder visible
models/checkpoints/*
!models/checkpoints/.gitkeep

# Exported SavedModel - ignore generated exports, keep folder visible
models/exported/*
!models/exported/.gitkeep

# TFLite - allow small models to be committed, keep folder visible
!models/tflite/
!models/tflite/.gitkeep
# Optional: ignore only large variants if needed later
# models/tflite/*.tmp

# Protobuf / checkpoint files
*.pb
*.pbtxt
*.ckpt
*.ckpt.*
*.index
*.data-00000-of-00001
*.saved_model

# Results - ignore everything except metrics JSONs and README
results/*
!results/.gitkeep
!results/README.md
!results/metrics_*.json